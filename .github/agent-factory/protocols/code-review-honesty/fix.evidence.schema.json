{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "fix suggestions evidence",
  "type": "object",
  "required": ["fixes", "mode"],
  "properties": {
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "diff"],
        "properties": {
          "cluster_id": { "type": "string", "minLength": 1 },
          "diff": { "type": "string", "minLength": 1 }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "reason"],
        "properties": {
          "cluster_id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "mode": { "type": "string", "enum": ["edit"] }
  }
}
