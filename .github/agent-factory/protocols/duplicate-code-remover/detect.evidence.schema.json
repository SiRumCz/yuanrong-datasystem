{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "duplicate-code-remover detect evidence",
  "type": "object",
  "required": ["scanned", "patterns"],
  "additionalProperties": true,
  "properties": {
    "scanned": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Files/symbols the agent actually examined (proves it read the code; required even when patterns is empty)."
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "severity", "rationale", "locations"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "rationale": { "type": "string", "minLength": 1 },
          "locations": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["path", "start_line", "end_line", "existing_code"],
              "additionalProperties": true,
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "start_line": { "type": "integer", "minimum": 1 },
                "end_line": { "type": "integer", "minimum": 1 },
                "existing_code": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
