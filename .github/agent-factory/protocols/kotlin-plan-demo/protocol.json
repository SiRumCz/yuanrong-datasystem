{
  "name": "kotlin-plan-demo",
  "version": "0.3.0",
  "max_depth": 6,
  "_note": "Test protocol replicating the code-review PREFLIGHT topology (4-cluster fanout -> join-preflight -> preflight-gate -> done) with dedicated test-kotlin-* PLAN-ONLY agents. Each agent authors, as a Kotlin .kts in evidence.plan_kts, the plan of the tool calls IT would run for its real preflight role (gather/judge/rollup/gate) WITHOUT executing them; the kotlin-plan-present check gates the plan's form. Started by /kotlin-plan on a PR.",
  "triggers": [
    {
      "on": "issue_comment",
      "comment_prefix": "/kotlin-plan",
      "command": "start"
    }
  ],
  "states": [
    {
      "id": "preflight",
      "kind": "fanout",
      "label": "pre-flight adherence chain",
      "branches": [
        {
          "id": "adherence",
          "states": [
            {
              "id": "adherence-intro",
              "kind": "agent",
              "workflow": "test-kotlin-adherence-intro-agent",
              "evidence": "plan.evidence.schema.json",
              "max_iterations": 2,
              "params": {
                "require": [
                  "examined"
                ]
              },
              "checks": [
                {
                  "run": "kotlin-plan-present",
                  "on_fail": "iterate"
                }
              ]
            },
            {
              "id": "adherence-fanout",
              "kind": "fanout",
              "next": "join-adherence",
              "branches": [
                {
                  "id": "spec-solves-issue",
                  "states": [
                    {
                      "id": "spec-solves-issue-gather",
                      "kind": "agent",
                      "workflow": "test-kotlin-spec-solves-issue-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "params": {
                        "require": [
                          "verdict",
                          "examined"
                        ]
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    },
                    {
                      "id": "spec-solves-issue-judge",
                      "kind": "agent",
                      "workflow": "test-kotlin-spec-solves-issue-judge-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "inputs": [
                        {
                          "from": "spec-solves-issue-gather",
                          "as": "gather"
                        }
                      ],
                      "params": {
                        "leg": "spec-solves-issue",
                        "mode": "spec-solves"
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    }
                  ]
                },
                {
                  "id": "plan-implements-spec",
                  "states": [
                    {
                      "id": "plan-implements-spec-gather",
                      "kind": "agent",
                      "workflow": "test-kotlin-plan-implements-spec-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "params": {
                        "require": [
                          "verdict",
                          "examined"
                        ]
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    },
                    {
                      "id": "plan-implements-spec-judge",
                      "kind": "agent",
                      "workflow": "test-kotlin-plan-implements-spec-judge-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "inputs": [
                        {
                          "from": "plan-implements-spec-gather",
                          "as": "gather"
                        }
                      ],
                      "params": {
                        "leg": "plan-implements-spec",
                        "mode": "plan-spec"
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    }
                  ]
                },
                {
                  "id": "code-implements-plan",
                  "states": [
                    {
                      "id": "code-implements-plan-gather",
                      "kind": "agent",
                      "workflow": "test-kotlin-code-implements-plan-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "params": {
                        "require": [
                          "verdict",
                          "examined"
                        ]
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    },
                    {
                      "id": "code-implements-plan-judge",
                      "kind": "agent",
                      "workflow": "test-kotlin-code-implements-plan-judge-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "inputs": [
                        {
                          "from": "code-implements-plan-gather",
                          "as": "gather"
                        }
                      ],
                      "params": {
                        "leg": "code-implements-plan",
                        "mode": "code-plan"
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "join-adherence",
              "kind": "join",
              "of": "adherence-fanout"
            },
            {
              "id": "adherence-rollup",
              "kind": "agent",
              "workflow": "test-kotlin-adherence-rollup-agent",
              "evidence": "plan.evidence.schema.json",
              "max_iterations": 2,
              "inputs": [
                {
                  "from": "spec-solves-issue",
                  "as": "spec-solves-issue"
                },
                {
                  "from": "plan-implements-spec",
                  "as": "plan-implements-spec"
                },
                {
                  "from": "code-implements-plan",
                  "as": "code-implements-plan"
                }
              ],
              "params": {
                "legs": [
                  "spec-solves-issue",
                  "plan-implements-spec",
                  "code-implements-plan"
                ]
              },
              "checks": [
                {
                  "run": "kotlin-plan-present",
                  "on_fail": "iterate"
                }
              ]
            }
          ]
        },
        {
          "id": "mm-compliance",
          "states": [
            {
              "id": "mm-compliance-gather",
              "kind": "agent",
              "workflow": "test-kotlin-mm-compliance-gate",
              "evidence": "plan.evidence.schema.json",
              "max_iterations": 2,
              "params": {
                "require": [
                  "verdict"
                ]
              },
              "checks": [
                {
                  "run": "kotlin-plan-present",
                  "on_fail": "iterate"
                }
              ]
            },
            {
              "id": "mm-compliance-judge",
              "kind": "agent",
              "workflow": "test-kotlin-mm-compliance-judge-agent",
              "evidence": "plan.evidence.schema.json",
              "max_iterations": 2,
              "inputs": [
                {
                  "from": "mm-compliance-gather",
                  "as": "gather"
                }
              ],
              "params": {
                "leg": "mm-compliance",
                "mode": "mm"
              },
              "checks": [
                {
                  "run": "kotlin-plan-present",
                  "on_fail": "iterate"
                }
              ]
            }
          ]
        },
        {
          "id": "consistency",
          "states": [
            {
              "id": "consistency-intro",
              "kind": "agent",
              "workflow": "test-kotlin-consistency-intro-agent",
              "evidence": "plan.evidence.schema.json",
              "max_iterations": 2,
              "params": {
                "require": [
                  "examined"
                ]
              },
              "checks": [
                {
                  "run": "kotlin-plan-present",
                  "on_fail": "iterate"
                }
              ]
            },
            {
              "id": "consistency-fanout",
              "kind": "fanout",
              "next": "join-consistency",
              "branches": [
                {
                  "id": "docs-updated-appropriately",
                  "states": [
                    {
                      "id": "docs-updated-appropriately-gather",
                      "kind": "agent",
                      "workflow": "test-kotlin-docs-coherence-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "params": {
                        "require": [
                          "verdict",
                          "examined"
                        ]
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    },
                    {
                      "id": "docs-updated-appropriately-judge",
                      "kind": "agent",
                      "workflow": "test-kotlin-docs-updated-appropriately-judge-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "inputs": [
                        {
                          "from": "docs-updated-appropriately-gather",
                          "as": "gather"
                        }
                      ],
                      "params": {
                        "leg": "docs-updated-appropriately",
                        "mode": "coherence"
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    }
                  ]
                },
                {
                  "id": "tests-updated-appropriately",
                  "states": [
                    {
                      "id": "tests-updated-appropriately-gather",
                      "kind": "agent",
                      "workflow": "test-kotlin-tests-coherence-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "params": {
                        "require": [
                          "verdict",
                          "examined"
                        ]
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    },
                    {
                      "id": "tests-updated-appropriately-judge",
                      "kind": "agent",
                      "workflow": "test-kotlin-tests-updated-appropriately-judge-agent",
                      "evidence": "plan.evidence.schema.json",
                      "max_iterations": 2,
                      "inputs": [
                        {
                          "from": "tests-updated-appropriately-gather",
                          "as": "gather"
                        }
                      ],
                      "params": {
                        "leg": "tests-updated-appropriately",
                        "mode": "coherence"
                      },
                      "checks": [
                        {
                          "run": "kotlin-plan-present",
                          "on_fail": "iterate"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "id": "join-consistency",
              "kind": "join",
              "of": "consistency-fanout"
            },
            {
              "id": "consistency-rollup",
              "kind": "agent",
              "workflow": "test-kotlin-consistency-rollup-agent",
              "evidence": "plan.evidence.schema.json",
              "max_iterations": 2,
              "inputs": [
                {
                  "from": "docs-updated-appropriately",
                  "as": "docs-updated-appropriately"
                },
                {
                  "from": "tests-updated-appropriately",
                  "as": "tests-updated-appropriately"
                }
              ],
              "params": {
                "legs": [
                  "docs-updated-appropriately",
                  "tests-updated-appropriately"
                ]
              },
              "checks": [
                {
                  "run": "kotlin-plan-present",
                  "on_fail": "iterate"
                }
              ]
            }
          ]
        },
        {
          "id": "security",
          "states": [
            {
              "id": "security-gather",
              "kind": "agent",
              "workflow": "test-kotlin-security-gather-agent",
              "evidence": "plan.evidence.schema.json",
              "max_iterations": 2,
              "checks": [
                {
                  "run": "kotlin-plan-present",
                  "on_fail": "iterate"
                }
              ]
            },
            {
              "id": "security-judge",
              "kind": "agent",
              "workflow": "test-kotlin-security-judge-agent",
              "evidence": "plan.evidence.schema.json",
              "max_iterations": 2,
              "inputs": [
                {
                  "from": "security-gather",
                  "as": "gather"
                }
              ],
              "params": {
                "leg": "security",
                "mode": "security"
              },
              "checks": [
                {
                  "run": "kotlin-plan-present",
                  "on_fail": "iterate"
                }
              ]
            }
          ]
        }
      ],
      "next": "join-preflight"
    },
    {
      "id": "join-preflight",
      "kind": "join",
      "of": "preflight",
      "next": "preflight-gate"
    },
    {
      "id": "preflight-gate",
      "kind": "agent",
      "label": "pre-flight gate (plan-only, terminal)",
      "workflow": "test-kotlin-preflight-gate-agent",
      "evidence": "plan.evidence.schema.json",
      "max_iterations": 2,
      "checks": [
        {
          "run": "kotlin-plan-present",
          "on_fail": "iterate"
        }
      ]
    }
  ]
}
